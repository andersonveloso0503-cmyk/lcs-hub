EVOLUTION_INSTANCE=lcs_crm
EVOLUTION_TOKEN=251EAE7F1D35-423F-BD4A-5E79555F1521

# Anthropic (geração de legendas do Instagram) - usada apenas no servidor (api/generate-caption.js)
ANTHROPIC_API_KEY=

# Buffer API (agendamento de posts no Instagram e Facebook) - usada apenas no servidor (api/buffer-schedule.js)
BUFFER_API_KEY=

# Channel ID da página do Facebook conectada no Buffer (obtido via consulta à API do Buffer
# depois de conectar a página) - sem isso, posts só vão para o Instagram
FACEBOOK_CHANNEL_ID=

# Vercel Blob (armazenamento de imagens dos posts) - usada apenas no servidor (api/upload-image.js)
BLOB_READ_WRITE_TOKEN=
